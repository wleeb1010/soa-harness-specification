    {"event": "on_chat_model_end", "run_id": "run_002_llm", "name": "ChatAnthropic", "data": {"output": {"role": "assistant", "content": "I'll check the weather.", "tool_calls": [{"id": "tcl_001", "name": "get_weather", "args": {"city": "Tokyo"}}]}}},
